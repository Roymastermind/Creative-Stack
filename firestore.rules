rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Default-Deny Catch-All Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper functions - updated to support guest access
    function isSignedIn() {
      return true; // Optional/guest signatures supported
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Help primitives
    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Room Rules (Dynamic Real-time Multi-user State Synchronization)
    match /rooms/{roomId} {
      allow read: if true;
      
      // Verification helper for lobby registration or lobby state updates
      function isValidRoom(data) {
        return data.id is string && data.id.size() <= 128
          && data.name is string && data.name.size() <= 128
          && data.hostId is string && data.hostId.size() <= 128
          && data.status is string && (data.status == 'lobby' || data.status == 'bidding' || data.status == 'paused' || data.status == 'finished')
          && data.members is map;
      }

      allow create: if isValidId(roomId) && isValidRoom(incoming()) && (request.auth == null || incoming().hostId == request.auth.uid);
      
      allow update: if isValidId(roomId) && isValidRoom(incoming()) && (
        // Action 1: Room Host updating global status or game control configuration
        (request.auth == null || existing().hostId == request.auth.uid) ||
        // Action 2: Player Joining - adding themselves to the members map
        (incoming().diff(existing()).affectedKeys().hasOnly(['members', 'createdAt', 'playerPoolIds'])) ||
        // Action 3: Placing Bid - updating current bidding parameters
        (incoming().diff(existing()).affectedKeys().hasOnly(['currentBidLakhs', 'currentBidderId', 'currentBidderName', 'timerExpiresAt']))
      );

      allow delete: if (request.auth == null || existing().hostId == request.auth.uid);
    }

    // 3. Chat rules (Conversational ledger)
    match /rooms/{roomId}/chats/{chatId} {
      allow read: if true;
      
      function isValidChat(data) {
        return data.id is string && data.id.size() <= 128
          && data.senderId is string && (request.auth == null || data.senderId == request.auth.uid || data.senderId == 'SYSTEM_BOT')
          && data.senderName is string && data.senderName.size() <= 64
          && data.text is string && data.text.size() <= 500;
      }

      allow create: if isValidId(chatId) && isValidChat(incoming());
      allow update: if false; // Chats are immutable
      allow delete: if false;
    }

    // 4. Draft Logs / Transactions (Auditable Ledger logs)
    match /rooms/{roomId}/logs/{logId} {
      allow read: if true;
      
      function isValidLog(data) {
        return data.id is string && data.id.size() <= 128
          && data.type is string && data.type.size() <= 32
          && data.message is string && data.message.size() <= 256;
      }

      allow create: if isValidId(logId) && isValidLog(incoming());
      allow update, delete: if false; // Logs are write-once, never delete
    }

    // 5. WebRTC P2P Voice Chat Signal rules (Presence signaling)
    match /rooms/{roomId}/signals/{signalId} {
      allow read: if true;
      
      function isValidSignal(data) {
        return data.senderId is string && (request.auth == null || data.senderId == request.auth.uid)
          && data.targetId is string && data.targetId.size() <= 128
          && data.type is string && (data.type == 'offer' || data.type == 'answer' || data.type == 'candidate')
          && data.payload is string && data.payload.size() <= 32768;
      }

      allow create: if isValidId(signalId) && isValidSignal(incoming());
      allow update, delete: if (request.auth == null || existing().senderId == request.auth.uid || existing().targetId == request.auth.uid);
    }
  }
}
